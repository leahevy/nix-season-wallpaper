#!/usr/bin/env bash
set -euo pipefail

year="${1:-}"
if [[ -z "$year" || ! "$year" =~ ^[0-9]{4}$ ]]; then
  echo "Usage: $0 YEAR" >&2
  exit 2
fi

if ! command -v nix >/dev/null 2>&1; then
  echo "Error: nix not found in PATH" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq not found in PATH" >&2
  exit 1
fi

stderr_tmp="$(mktemp -t nix-season-wallpaper.test-flake.XXXXXX)"
cleanup() {
  rm -f -- "$stderr_tmp"
}
trap cleanup EXIT

print_stderr_filtered() {
  if [[ ! -s "$stderr_tmp" ]]; then
    return 0
  fi
  grep -v "warning: Git tree '.*' is dirty" "$stderr_tmp" >&2 || true
}

days_in_month() {
  local y="$1"
  local m="$2"
  case "$m" in
    1|3|5|7|8|10|12) echo 31 ;;
    4|6|9|11) echo 30 ;;
    2)
      if (( (y % 4 == 0 && y % 100 != 0) || (y % 400 == 0) )); then
        echo 29
      else
        echo 28
      fi
      ;;
    *)
      echo "invalid month: $m" >&2
      exit 2
      ;;
  esac
}

check_json() {
  local route="$1"
  local y="$2"
  local m="$3"
  local d="$4"
  local json
  local nix_expr="f: f { year = ${y}; month = ${m}; day = ${d}; }"

  : >"$stderr_tmp"
  if ! json="$(nix eval --json ".#${route}" --apply "$nix_expr" 2>"$stderr_tmp")"; then
    echo "Error: nix eval failed route=${route} date=${y}-${m}-${d}" >&2
    : >"$stderr_tmp"
    nix eval --json ".#${route}" --apply "$nix_expr" >/dev/null 2>"$stderr_tmp" || true
    print_stderr_filtered
    return 1
  fi

  jq -e '
    (.metadata | type) == "object" and (.metadata | length) > 0
    and (.widescreen.path | type) == "string"
    and (.normal.path | type) == "string"
    and (.widescreen.path | startswith("/nix/store/"))
    and (.normal.path | startswith("/nix/store/"))
    and (.widescreen.path | endswith(".jpg"))
    and (.normal.path | endswith(".jpg"))
    and (.normal.path | contains("-normal-"))
    and (.widescreen.path | contains("-widescreen-"))
    and ((.widescreen.path | contains("-normal-")) | not)
    and (.metadata | has("festival"))
    and (.metadata.festival == null or (.metadata.festival | type) == "string")
  ' >/dev/null <<<"$json" || {
    echo "Error: validation failed route=${route} date=${y}-${m}-${d}" >&2
    : >"$stderr_tmp"
    nix eval --json ".#${route}" --apply "$nix_expr" 2>"$stderr_tmp"
    print_stderr_filtered
    return 1
  }

  printf '%s\n' "$json"
}

ok_season=0
ok_daily=0
total=0
declare -A festivals_seen
declare -A festival_seen_by_season

for month in {1..12}; do
  dim="$(days_in_month "$year" "$month")"
  month_festivals=0
  unset -v month_festivals_seen 2>/dev/null || true
  declare -A month_festivals_seen
  for day in $(seq 1 "$dim"); do
    season_json="$(check_json resolveWallpaperBySeason "$year" "$month" "$day")"
    ok_season=$(( ok_season + 1 ))

    season_name="$(jq -r '.metadata.season' <<<"$season_json")"
    festival_name="$(jq -r '.metadata.festival // ""' <<<"$season_json")"
    if [[ -n "$festival_name" ]]; then
      if [[ -z "${month_festivals_seen[$festival_name]-}" ]]; then
        month_festivals_seen["$festival_name"]=1
        month_festivals=$(( month_festivals + 1 ))
      fi
      festivals_seen["$festival_name"]=1
      festival_seen_by_season["$season_name"]=1
    fi

    daily_json="$(check_json resolveDailyWallpaper "$year" "$month" "$day")"
    jq -e '.metadata.festival == null' >/dev/null <<<"$daily_json" || {
      echo "Error: daily route festival must be null date=${year}-${month}-${day}" >&2
      echo "$daily_json" >&2
      exit 1
    }
    ok_daily=$(( ok_daily + 1 ))

    total=$(( total + 1 ))
  done
  printf 'ok: %s-%02d days=%d festivals=%d\n' "$year" "$month" "$dim" "$month_festivals"
done

for season in winter spring summer autumn; do
  if [[ -z "${festival_seen_by_season[$season]-}" ]]; then
    echo "Error: did not observe any festival for season=$season in year=$year" >&2
    exit 1
  fi
done

festival_count=0
for _ in "${!festivals_seen[@]}"; do
  festival_count=$(( festival_count + 1 ))
done
if (( festival_count < 4 )); then
  echo "Error: expected >=4 festivals observed in year=$year, got $festival_count" >&2
  exit 1
fi

echo "ok: year=$year days=$total season=$ok_season daily=$ok_daily"
